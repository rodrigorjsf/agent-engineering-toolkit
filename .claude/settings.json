{
  "env": {
    "CLAUDE_CODE_EXPERIMENTAL_AGENT_TEAMS": "1",
    "DISABLE_PROMPT_CACHING": "false",
    "ENABLE_TOOL_SEARCH": "true",
    "CLAUDE_CODE_DISABLE_THINKING": "false"
  },
  "permissions": {
    "deny": [
      "Read(/next-steps.md)",
      "Read(/docs/plans/**)",
      "Read(/.claude/PRPs/plans/completed/**)",
      "Read(/.claude/PRPs/prds/completed/**)"
    ]
  },
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": ".claude/hooks/check-docs-sync.sh"
          }
        ]
      },
      {
        "matcher": "Edit|Write|MultiEdit",
        "hooks": [
          {
            "type": "command",
            "command": ".claude/hooks/check-skill-self-containment-hook.sh"
          }
        ]
      }
    ]
  },
  "enabledPlugins": {
    "compound-engineering@compound-engineering-plugin": true,
    "agents-initializer@agent-engineering-toolkit": true
  }
}
